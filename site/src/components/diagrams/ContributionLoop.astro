---
// The contribution loop: an audit finds a gap, a skill gets written and merged,
// the site and agent endpoints regenerate on their own.
---

<svg
  viewBox="0 0 520 480"
  role="img"
  aria-label="Contribution loop: an audit finds an uncovered issue, a new skill is drafted and merged as a pull request, and the site pages and agent endpoints regenerate automatically"
  class="w-full h-auto font-sans"
>
  <defs>
    <marker id="cl-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 1 L 8 5 L 0 9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
      ></path>
    </marker>
  </defs>

  <g>
    <rect x="130" y="20" width="260" height="72" rx="12" class="fill-white dark:fill-slate-900 stroke-gray-300 dark:stroke-slate-700" stroke-width="1.5"></rect>
    <text x="260" y="50" text-anchor="middle" font-size="16" class="fill-gray-900 dark:fill-white font-bold">audit finds a gap</text>
    <text x="260" y="74" text-anchor="middle" font-size="13" class="fill-gray-500 dark:fill-slate-400">an issue no skill covers yet</text>

    <rect x="130" y="150" width="260" height="72" rx="12" class="fill-white dark:fill-slate-900 stroke-gray-300 dark:stroke-slate-700" stroke-width="1.5"></rect>
    <text x="260" y="180" text-anchor="middle" font-size="16" class="fill-gray-900 dark:fill-white font-bold">Claude drafts the skill</text>
    <text x="260" y="204" text-anchor="middle" font-size="13" class="fill-gray-500 dark:fill-slate-400 font-mono">skills/&lt;name&gt;/SKILL.md</text>

    <rect x="130" y="280" width="260" height="72" rx="12" class="fill-white dark:fill-slate-900 stroke-gray-300 dark:stroke-slate-700" stroke-width="1.5"></rect>
    <text x="260" y="310" text-anchor="middle" font-size="16" class="fill-gray-900 dark:fill-white font-bold">PR merged</text>
    <text x="260" y="334" text-anchor="middle" font-size="13" class="fill-gray-500 dark:fill-slate-400">frontmatter checked by the deploy preview</text>

    <rect x="130" y="410" width="260" height="64" rx="12" class="fill-blue-50 dark:fill-slate-800 stroke-primary" stroke-width="1.5"></rect>
    <text x="260" y="438" text-anchor="middle" font-size="16" class="fill-primary font-bold">pages regenerate</text>
    <text x="260" y="460" text-anchor="middle" font-size="13" class="fill-gray-500 dark:fill-slate-400">skill page, .md twin, llms.txt, skills.json</text>
  </g>

  <g class="text-gray-400 dark:text-slate-500">
    <line x1="260" y1="92" x2="260" y2="142" stroke="currentColor" stroke-width="1.8" marker-end="url(#cl-arrow)"></line>
    <line x1="260" y1="222" x2="260" y2="272" stroke="currentColor" stroke-width="1.8" marker-end="url(#cl-arrow)"></line>
    <line x1="260" y1="352" x2="260" y2="402" stroke="currentColor" stroke-width="1.8" marker-end="url(#cl-arrow)"></line>
    <!-- loop back -->
    <path
      d="M 390 442 C 480 442 480 56 398 56"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-dasharray="5 5"
      marker-end="url(#cl-arrow)"></path>
    <text x="500" y="250" font-size="13" text-anchor="middle" class="fill-gray-500 dark:fill-slate-400" transform="rotate(90 500 250)">the next admin benefits</text>
  </g>
</svg>
