---
import { GITHUB_REPO_URL } from '~/lib/skills';
---

<div
  class="text-sm bg-slate-900 text-slate-300 dark:bg-transparent dark:border-b dark:border-slate-800 dark:text-slate-400 hidden md:flex gap-1 overflow-hidden px-3 py-2 relative text-ellipsis whitespace-nowrap"
>
  <span
    class="bg-white/20 dark:bg-slate-700 text-slate-100 dark:text-slate-300 font-semibold px-1 py-0.5 text-xs mr-0.5 rtl:mr-0 rtl:ml-0.5 inline-block"
    >OPEN SOURCE</span
  >
  <a href={GITHUB_REPO_URL} class="text-slate-300 hover:underline dark:text-slate-400 font-medium" rel="noopener"
    >32 free Claude Code skills for HubSpot admins — star the repo »</a
  >
</div>
