---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import StructuredData from '~/components/StructuredData.astro';
import AuditReport from '~/components/diagrams/AuditReport.astro';
import SafetyPipeline from '~/components/diagrams/SafetyPipeline.astro';
import AgentSurfaces from '~/components/diagrams/AgentSurfaces.astro';

import { CATEGORIES } from '~/data/categories';
import { PROBLEMS } from '~/data/problems';
import { getSkills, GITHUB_REPO_URL, MARKETPLACE_ADD_COMMAND, PLUGIN_INSTALL_COMMAND } from '~/lib/skills';
import { organizationSchema, websiteSchema } from '~/lib/structuredData';

const skills = await getSkills();
const scriptedCount = skills.filter((s) => s.scriptFiles.length > 0).length;

const metadata = {
  title: 'HubSpot Admin Skills — the CRM cleanup you keep postponing, run by Claude Code',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <StructuredData schema={[websiteSchema(), organizationSchema()]} />
  </Fragment>

  <Hero
    actions={[
      { variant: 'primary', text: 'Install the plugin', href: '/install', icon: 'tabler:terminal-2' },
      { text: 'Browse all skills', href: '/skills' },
    ]}
  >
    <Fragment slot="title">
      The HubSpot cleanup you keep postponing, <span class="text-accent dark:text-white">run by Claude Code</span>
    </Fragment>

    <Fragment slot="subtitle">
      Duplicate companies, hard bounces still marked marketable, a third of your contacts missing a lifecycle stage.
      You know the backlog. These {skills.length} open-source skills work through it: each one audits first, exports a
      CSV baseline, makes the change, and shows you the before/after.
    </Fragment>

    <Fragment slot="image">
      <AuditReport />
    </Fragment>
  </Hero>

  <Note title="The loop:" description="Audit your portal → get a phased plan → execute skill by skill → maintain" />

  <Steps
    id="workflow"
    title="What a cleanup actually looks like"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Audit</span>',
        description:
          'Run <code>/hubspot-audit</code>. Read-only API queries across eight dimensions: contacts, deliverability, duplicates, owners, lifecycle, lists, workflows, pipeline. Every finding gets a grade and the name of the skill that fixes it.',
        icon: 'tabler:report-search',
      },
      {
        title: 'Step 2: <span class="font-medium">Plan</span>',
        description:
          'Run <code>/hubspot-implementation-plan</code>. It orders the fixes by dependency: you can\'t score leads on firmographics nobody backfilled, so enrichment comes before scoring, hygiene before both.',
        icon: 'tabler:route',
      },
      {
        title: 'Step 3: <span class="font-medium">Execute</span>',
        description:
          'One skill per finding. Destructive skills export a CSV baseline before touching anything, stop at an abort threshold, and document the rollback. Workflows are created disabled so you review them in the UI first.',
        icon: 'tabler:player-play',
      },
      {
        title: 'Step 4: <span class="font-medium">Maintain</span>',
        description:
          'Prevention workflows screen new records at creation. <code>/weekly-cleanup-routine</code> is a five-minute check; <code>/quarterly-database-cleanup</code> handles the drift both miss.',
        icon: 'tabler:calendar-repeat',
      },
    ]}
  >
    <Fragment slot="image">
      <SafetyPipeline />
    </Fragment>
  </Steps>

  <Features
    id="categories"
    tagline="Skill categories"
    title="Skills for every phase of the CRM lifecycle"
    subtitle={`${skills.length} skills across six categories. ${scriptedCount} ship with ready-to-run Python scripts.`}
    columns={3}
    items={CATEGORIES.map((category) => ({
      title: category.title,
      description: category.description,
      icon: category.icon,
      callToAction: { text: 'View skills', href: `/categories/${category.slug}` },
    }))}
  />

  <Content
    isReversed
    tagline="For AI agents"
    title="Built to be read by agents, not scraped"
    items={[
      {
        title: 'llms.txt and llms-full.txt',
        description: 'An index of every skill, and the full documentation in one fetch.',
      },
      {
        title: 'Raw markdown twins',
        description: 'Every skill page has a .md URL serving the SKILL.md verbatim, frontmatter included.',
      },
      {
        title: 'skills.json',
        description: 'The whole catalog as JSON: slugs, categories, script URLs, install commands.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Point your agent at this site</h3>
      If an agent does your HubSpot work, it can read this site directly and run any skill against your portal with
      your own token.
      <a class="text-primary hover:underline" href="/install#agents">Agent install guide →</a>
    </Fragment>

    <Fragment slot="image">
      <AgentSurfaces />
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Stats
    stats={[
      { title: 'Skills', amount: `${skills.length}` },
      { title: 'With Python scripts', amount: `${scriptedCount}` },
      { title: 'Common problems covered', amount: `${PROBLEMS.length}` },
      { title: 'License', amount: 'MIT' },
    ]}
  />

  <FAQs
    title="The questions that decide whether you run this"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Is this safe to run against production?',
        description:
          'The audit is read-only. Skills that change data export a CSV of every affected record first, show you what will change, ask before writing, and stop at an abort threshold. Run /sandbox-self-test against a free HubSpot developer test account if you want proof before granting a production token.',
      },
      {
        title: 'Where does my CRM data go?',
        description:
          'Nowhere. There is no SaaS here. The skills are markdown instructions plus Python scripts that run on your machine, calling the HubSpot API with your own private app token. CSV exports stay in a local, gitignored folder.',
      },
      {
        title: 'What do I need?',
        description:
          'Claude Code, a HubSpot private app token, and Python 3.10+ with uv for the scripted skills. Workflow skills need Marketing Professional or higher; the audit and hygiene skills work on any tier.',
      },
      {
        title: "What if the audit finds something no skill covers?",
        description:
          'It offers to write the skill on the spot, and to contribute it back as a pull request. The skill set grows out of real portals, not a roadmap.',
      },
      {
        title: 'Is this a HubSpot product?',
        description:
          'No. Independent open source, built from years of administering HubSpot portals. It works inside your existing portal; nothing gets replaced. HubSpot is a trademark of HubSpot, Inc.',
      },
    ]}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Install the plugin', href: '/install', icon: 'tabler:terminal-2' },
      { text: 'Star on GitHub', href: GITHUB_REPO_URL, target: '_blank', icon: 'tabler:brand-github' },
    ]}
  >
    <Fragment slot="title">Two commands and you're auditing</Fragment>
    <Fragment slot="subtitle">
      <code class="block text-sm">{MARKETPLACE_ADD_COMMAND}</code>
      <code class="block text-sm mt-1">{PLUGIN_INSTALL_COMMAND}</code>
    </Fragment>
  </CallToAction>
</Layout>
